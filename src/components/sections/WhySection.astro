---
import WhyCardCarousel from '@/components/sections/WhyCardCarousel.astro';
import { whyCardCarousels } from '@/config/why-media';
import type { Dictionary } from '@/lib/i18n';

interface Props {
  copy: Dictionary;
}

const { copy } = Astro.props;
---

<section id="why" class="scroll-mt-20 border-b border-temple-snow/10 py-16 md:py-20">
  <div class="container-shell">
    <p class="section-eyebrow">{copy.why.eyebrow}</p>
    <h2 class="mt-2 max-w-2xl text-3xl font-bold tracking-tight text-temple-snow md:text-4xl">
      {copy.why.title}
    </h2>
    <p class="mt-4 max-w-2xl text-temple-snow/80">{copy.why.description}</p>

    <ul class="why-cards mt-10 grid list-none gap-6 p-0 md:grid-cols-3">
      {copy.why.cards.map((card, index) => (
        <li class="why-card">
          <div class="why-card__media">
            <WhyCardCarousel slides={whyCardCarousels[index]} label={card.title} />
          </div>
          <div class="why-card__body">
            <h3 class="why-card__title">{card.title}</h3>
            <p class="why-card__text">{card.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  function initWhyCarousels() {
    document.querySelectorAll('.why-carousel').forEach((root) => {
      if (root.dataset.initialized === 'true') return;

      const viewport = root.querySelector('.why-carousel__viewport');
      const slideEls = root.querySelectorAll('.why-carousel__slide');
      const dots = root.querySelectorAll('.why-carousel__dot');
      const prevBtn = root.querySelector('.why-carousel__arrow--prev');
      const nextBtn = root.querySelector('.why-carousel__arrow--next');

      if (!viewport || slideEls.length === 0) return;

      root.dataset.initialized = 'true';

      const setActive = (index) => {
        const clamped = Math.max(0, Math.min(index, slideEls.length - 1));
        slideEls.forEach((slide, i) => {
          slide.setAttribute('aria-hidden', i === clamped ? 'false' : 'true');
        });
        dots.forEach((dot, i) => {
          const active = i === clamped;
          dot.classList.toggle('is-active', active);
          dot.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        if (prevBtn) prevBtn.disabled = clamped <= 0;
        if (nextBtn) nextBtn.disabled = clamped >= slideEls.length - 1;
      };

      const getIndex = () => {
        const slideWidth = viewport.clientWidth;
        if (!slideWidth) return 0;
        return Math.round(viewport.scrollLeft / slideWidth);
      };

      const scrollToIndex = (index) => {
        const clamped = Math.max(0, Math.min(index, slideEls.length - 1));
        viewport.scrollTo({ left: clamped * viewport.clientWidth, behavior: 'smooth' });
        setActive(clamped);
      };

      let scrollTimer;
      viewport.addEventListener(
        'scroll',
        () => {
          if (scrollTimer) clearTimeout(scrollTimer);
          scrollTimer = setTimeout(() => setActive(getIndex()), 60);
        },
        { passive: true },
      );

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          scrollToIndex(Number(dot.dataset.index ?? 0));
        });
      });

      prevBtn?.addEventListener('click', () => scrollToIndex(getIndex() - 1));
      nextBtn?.addEventListener('click', () => scrollToIndex(getIndex() + 1));

      viewport.addEventListener('keydown', (event) => {
        const current = getIndex();
        if (event.key === 'ArrowRight' && current < slideEls.length - 1) {
          event.preventDefault();
          scrollToIndex(current + 1);
        }
        if (event.key === 'ArrowLeft' && current > 0) {
          event.preventDefault();
          scrollToIndex(current - 1);
        }
      });

      setActive(0);
    });
  }

  initWhyCarousels();
  document.addEventListener('astro:page-load', initWhyCarousels);
</script>
