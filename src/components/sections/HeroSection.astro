---
import CtaLink from '@/components/CtaLink.astro';
import HeroBackground from '@/components/sections/HeroBackground.astro';
import { siteConfig } from '@/config/site';
import type { Dictionary } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import { trialUrl } from '@/lib/urls';

interface Props {
  locale: Locale;
  copy: Dictionary;
}

const { locale, copy } = Astro.props;
const { business } = siteConfig;
---

<section class="hero-section">
  <HeroBackground />

  <div class="hero-content container-shell">
    <div class="animate-fade-up hero-content__inner">
      <p class="section-eyebrow">{copy.hero.eyebrow}</p>
      <h1 class="mt-3">
        <span class="hero-wordmark-top block">{copy.hero.titleLine1}</span>
        <span class="hero-wordmark-top hero-wordmark-accent block">{copy.hero.titleLine2}</span>
      </h1>
      <p class="mt-5 max-w-lg text-lg text-temple-snow/90">{copy.hero.subtitle}</p>

      <div class="hero-cta-stack mt-8">
        <p class="hero-cta-badge">
          <span class="hero-cta-badge-dot" aria-hidden="true"></span>
          {copy.hero.firstClassFree}
        </p>

        <CtaLink
          href={trialUrl(locale)}
          event="cta_free_class"
          variant="primary"
          class="cta-btn--block"
        >
          {copy.hero.bookTrial}
        </CtaLink>

        <p class="hero-cta-quick-label">{copy.hero.quickContact}</p>

        <div class="hero-cta-quick-grid">
          <CtaLink href={`tel:${business.phoneTel}`} event="cta_call" variant="outline" class="cta-btn--block">
            {copy.hero.call}
          </CtaLink>
          <CtaLink href={`sms:${business.smsTel}`} event="cta_text" variant="outline" class="cta-btn--block">
            {copy.hero.text}
          </CtaLink>
          <CtaLink
            href={business.mapUrl}
            event="cta_directions"
            variant="outline"
            class="cta-btn--block"
            target="_blank"
            rel="noopener noreferrer"
          >
            {copy.hero.directions}
          </CtaLink>
        </div>
      </div>
    </div>
  </div>
</section>
