# Temple Underground marketing minisite (TU-marketing)
# Copy to `.env` for local development. On Vercel, set these in Project → Settings → Environment Variables.
# Only variables prefixed with PUBLIC_ are exposed to the browser.

# -----------------------------------------------------------------------------
# Lead capture (required in production)
# -----------------------------------------------------------------------------
# Signup API endpoint for the book-page form (POST /api/lead).
# Local dev: leave empty to use http://localhost:3001/api/lead when the API is running.
# Production example:
# PUBLIC_LEAD_API_URL=https://api.templeunderground.com/api/lead
PUBLIC_LEAD_API_URL=

# -----------------------------------------------------------------------------
# Site links
# -----------------------------------------------------------------------------
# Full main website (footer / nav “Full website” link).
PUBLIC_PRIMARY_SITE_URL=https://templeunderground.com

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# Plausible domain, e.g. go.templeunderground.com — leave empty to disable.
PUBLIC_PLAUSIBLE_DOMAIN=

# -----------------------------------------------------------------------------
# Assets (optional)
# -----------------------------------------------------------------------------
# Shared CDN base for marketing images — see ../SHARED-ASSETS.md
PUBLIC_ASSETS_CDN_URL=
