# Plausible analytics (optional — leave empty to disable)
PUBLIC_PLAUSIBLE_DOMAIN=

# Override primary website URL (optional)
PUBLIC_PRIMARY_SITE_URL=https://templeunderground.com

# Lead API — POST /api/lead on the Temple Underground signup API (required in production)
# Local dev defaults to http://localhost:3001/api/lead when unset
PUBLIC_LEAD_API_URL=

# Shared marketing CDN (optional — see ../SHARED-ASSETS.md)
PUBLIC_ASSETS_CDN_URL=
